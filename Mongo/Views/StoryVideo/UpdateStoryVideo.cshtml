@model Mongo.Dtos.StoryVideoDto.GetStoryVideoByIdDto
@{
    ViewData["Title"] = "Hikaye Videosunu Güncelle";
    Layout = "~/Views/Admin/AdminLaoyut.cshtml";
}

<div class="row">
    <div class="col-md-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Hikaye Videosunu Güncelle</h4>
                <p class="card-description">Mevcut video alanına ait bilgileri buradan güncelleyebilirsiniz.</p>
                
                <form class="forms-sample" method="post" action="/StoryVideo/UpdateStoryVideo">
                    
                    <input type="hidden" name="StoryVideoId" value="@Model.StoryVideoId" />

                    <div class="form-group">
                        <label for="Title">Başlık</label>
                        <input type="text" class="form-control" id="Title" name="Title" value="@Model.Title" required>
                    </div>

                    <div class="form-group">
                        <label for="ImageUrl">Kapak Görseli URL</label>
                        <input type="text" class="form-control" id="ImageUrl" name="ImageUrl" value="@Model.ImageUrl" required>
                    </div>

                    <div class="form-group">
                        <label for="VideoUrl">Video Linki</label>
                        <input type="text" class="form-control" id="VideoUrl" name="VideoUrl" value="@Model.VideoUrl" required>
                    </div>

                    <div class="form-group">
                        <label for="Description">Kısa Açıklama</label>
                        <textarea class="form-control" id="Description" name="Description" rows="4" required>@Model.Description</textarea>
                    </div>

                    <button type="submit" class="btn btn-primary mr-2">Değişiklikleri Kaydet</button>
                    <a href="/StoryVideo/StoryVideoList" class="btn btn-light">İptal Et</a>
                    
                </form>
            </div>
        </div>
    </div>
</div>