@model List<Mongo.Dtos.StoryVideoDto.ResultStoryVideoDto>
    @{
        ViewData["Title"] = "Hikaye Videosu Yönetimi";
        Layout = "~/Views/Admin/AdminLaoyut.cshtml";
    }

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body">
                    <h4 class="card-title">Hikayemiz Videosu Yönetimi</h4>
                    <p class="card-description">Ana sayfadaki tanıtım videosunu, kapak görselini ve ilgili başlık yazılarını buradan yönetebilirsiniz.</p>
                
                    <div class="table-responsive pt-3">
                        <table class="table table-striped project-orders-table">
                            <thead>
                                <tr>
                                    <th>Kapak Görseli</th>
                                    <th>Başlık</th>
                                    <th>Açıklama</th>
                                    <th>Video Linki</th>
                                    <th>İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                <img src="@item.ImageUrl" alt="Video Kapağı" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;" />
                                            </td>
                                            <td class="font-weight-bold">@item.Title</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(item.Description))
                                                {
                                                    @(item.Description.Length > 50 ? item.Description.Substring(0, 50) + "..." : item.Description)
                                                }
                                            </td>
                                            <td>
                                                <a href="@item.VideoUrl" target="_blank" class="text-info text-decoration-none">
                                                    <i class="typcn typcn-media-play mr-1"></i> Videoyu Aç
                                                </a>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <a href="/StoryVideo/UpdateStoryVideo/@item.StoryVideoId" class="btn btn-success btn-sm btn-icon-text mr-3">
                                                        Düzenle
                                                        <i class="typcn typcn-edit btn-icon-append"></i>
                                                    </a>
                                                    <a href="/StoryVideo/DeleteStoryVideo/@item.StoryVideoId" class="btn btn-danger btn-sm btn-icon-text" onclick="return confirm('Bu video içeriğini silmek istediğinize emin misiniz?')">
                                                        Sil
                                                        <i class="typcn typcn-delete-outline btn-icon-append"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted">Veri tabanında henüz video kaydı bulunmuyor.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                
                    @if (Model == null || !Model.Any())
                    {
                        <div class="mt-4">
                            <a href="/StoryVideo/CreateStoryVideo" class="btn btn-info btn-icon-text">
                                <i class="typcn typcn-plus mr-2"></i> Hikaye Videosu Ekle
                            </a>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>