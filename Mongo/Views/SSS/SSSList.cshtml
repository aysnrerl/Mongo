@model List<Mongo.Dtos.SSSDto.ResultSSSDto>
@{
    ViewData["Title"] = "SSSList";
    Layout = "~/Views/Admin/AdminLaoyut.cshtml"; 
    int count = 0; 
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Sıkça Sorulan Sorular Listesi</h4>
                <p class="card-description">Müşterilerin ana sayfada göreceği soru ve cevapları buradan yönetebilirsiniz.</p>
                
                <div class="table-responsive pt-3">
                    <table class="table table-striped project-orders-table">
                        <thead>
                            <tr>
                                <th class="ml-5">#</th>
                                <th>Soru</th>
                                <th>Cevap</th>
                                <th>Sıra No</th>
                                <th>Durum</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    count++;
                                    <tr>
                                        <td>#@count</td>
                                        
                                        <td class="font-weight-bold">@item.Question</td>
                                        
                                        <td>@(item.Answer.Length > 60 ? item.Answer.Substring(0, 60) + "..." : item.Answer)</td>
                                        
                                        <td>@item.Order</td>
                                        
                                        <td>
                                            @if (item.IsActive)
                                            {
                                                <span class="badge badge-success text-white">Aktif</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-secondary">Pasif</span>
                                            }
                                        </td>
                                        
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <a href="/SSS/UpdateSSS/@item.SSSId" class="btn btn-success btn-sm btn-icon-text mr-3">
                                                    Düzenle
                                                    <i class="typcn typcn-edit btn-icon-append"></i>
                                                </a>
                                                <a href="/SSS/DeleteSSS/@item.SSSId" class="btn btn-danger btn-sm btn-icon-text" onclick="return confirm('Bu soruyu silmek istediğinize emin misiniz?')">
                                                    Sil
                                                    <i class="typcn typcn-delete-outline btn-icon-append"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted">Veri tabanında henüz eklenmiş SSS verisi bulunmuyor.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                <div class="mt-4">
                    <a href="/SSS/CreateSSS" class="btn btn-info btn-icon-text">
                        <i class="typcn typcn-plus mr-2"></i> Yeni Soru Cevap Ekle
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>