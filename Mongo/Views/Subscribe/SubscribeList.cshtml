@model List<Mongo.Dtos.SubscribeDto.ResultSubscribeDto>
@{
    ViewData["Title"] = "E-Bülten Aboneleri";
    Layout = "~/Views/Admin/AdminLaoyut.cshtml";
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">E-Bülten Aboneleri</h4>
                <p class="card-description">Web siteniz üzerinden bültene, kampanyalara ve yeniliklere kayıt olmuş kullanıcıların listesi.</p>
                
                <div class="table-responsive pt-3">
                    <table class="table table-striped project-orders-table">
                        <thead>
                            <tr>
                                <th>Kayıt ID</th>
                                <th>Abone E-posta Adresi</th>
                                <th>Kayıt Tarihi</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.SubscribeId</td>
                                        <td class="font-weight-bold text-info">@item.Email</td>
                                        <td>@item.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <a href="/Subscribe/UpdateSubscribe/@item.SubscribeId" class="btn btn-success btn-sm btn-icon-text mr-3">
                                                    Düzenle
                                                    <i class="typcn typcn-edit btn-icon-append"></i>
                                                </a>
                                                <a href="/Subscribe/DeleteSubscribe/@item.SubscribeId" class="btn btn-danger btn-sm btn-icon-text" onclick="return confirm('Bu aboneyi bültenden silmek istediğinize emin misiniz?')">
                                                    Kaldır
                                                    <i class="typcn typcn-delete-outline btn-icon-append"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted">Bültene kayıtlı henüz hiç kullanıcı yok.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                <div class="mt-4">
                    <a href="/Subscribe/CreateSubscribe" class="btn btn-info btn-icon-text">
                        <i class="typcn typcn-plus mr-2"></i> Manuel Abone Ekle
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>