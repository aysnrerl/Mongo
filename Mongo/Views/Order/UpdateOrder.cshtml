@model Mongo.Dtos.OrderDto.GetOrderByIdDto
@{
    ViewData["Title"] = "Sipariş Durumu Yönetimi";
    Layout = "~/Views/Admin/AdminLaoyut.cshtml";
}

<div class="row">
    <div class="col-md-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Sipariş Güncelleme / Durum Yönetimi</h4>
                <p class="card-description">Sipariş aşamasını ilerletmek veya adres güncellemelerini işlemek için aşağıdaki alanları kullanın.</p>
                
                <form class="forms-sample" method="post" action="/Order/UpdateOrder">
                    
                    <input type="hidden" name="OrderId" value="@Model.OrderId" />
                    <input type="hidden" name="OrderDate" value="@Model.OrderDate.ToString("yyyy-MM-ddTHH:mm:ss")" />
                    <input type="hidden" name="TotalPrice" value="@Model.TotalPrice.ToString("0.00")" />
                    <input type="hidden" name="ProductId" value="@Model.ProductId" />

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Müşteri Adı</label>
                                <input type="text" class="form-control" name="CustomerName" value="@Model.CustomerName" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="Status">Sipariş Durumu</label>
                                <select class="form-control text-dark" id="Status" name="Status">
                                    <!option value="Beklemede" @(Model.Status == "Beklemede" ? "selected" : "")>Beklemede</!option>
                                    <!option value="Onaylandı" @(Model.Status == "Onaylandı" ? "selected" : "")>Onaylandı (Hazırlanıyor/Yolda)</!option>
                                    <!option value="İptal Edildi" @(Model.Status == "İptal Edildi" ? "selected" : "")>İptal Edildi</!option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <label>Ürün Adı</label>
                            <input type="text" class="form-control" name="ProductName" value="@Model.ProductName" required>
                        </div>
                        <div class="col-md-4">
                            <label>Adet</label>
                            <input type="number" class="form-control" name="Quantity" value="@Model.Quantity" required>
                        </div>
                        <div class="col-md-4">
                            <label>Birim Fiyat (₺)</label>
                            <input type="text" class="form-control" name="UnitPrice" value="@Model.UnitPrice.ToString("0.00")" required>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Müşteri E-posta</label>
                                <input type="email" class="form-control" name="CustomerEmail" value="@Model.CustomerEmail" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Telefon</label>
                                <input type="text" class="form-control" name="Phone" value="@Model.Phone" required>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Teslimat Adresi</label>
                        <textarea class="form-control" name="Address" rows="4" required>@Model.Address</textarea>
                    </div>

                    <button type="submit" class="btn btn-primary mr-2">Güncelleştirmeleri Kaydet</button>
                    <a href="/Order/OrderList" class="btn btn-light">İptal Et</a>
                    
                </form>
            </div>
        </div>
    </div>
</div>