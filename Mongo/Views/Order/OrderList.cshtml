@model List<Mongo.Dtos.OrderDto.ResultOrderDto>
@{
    ViewData["Title"] = "Sipariş Listesi";
    Layout = "~/Views/Admin/AdminLaoyut.cshtml";
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Gelen Siparişlerin Yönetimi</h4>
                <p class="card-description">Müşterilerinizin verdiği siparişleri, adres ve durum bilgilerini buradan takip edip güncelleyebilirsiniz.</p>
                
                <div class="table-responsive pt-3">
                    <table class="table table-striped project-orders-table">
                        <thead>
                            <tr>
                                <th>Müşteri Adı</th>
                                <th>Ürün Adı</th>
                                <th>Adet</th>
                                <th>Toplam Tutar</th>
                                <th>Tarih</th>
                                <th>Durum</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="font-weight-bold">
                                            @item.CustomerName <br />
                                            <small class="text-muted">@item.Phone</small>
                                        </td>
                                        <td>@item.ProductName</td>
                                        <td>@item.Quantity Adet</td>
                                        <td class="text-success font-weight-bold">@item.TotalPrice.ToString("C2")</td>
                                        <td>@item.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td>
                                            @if (item.Status == "Beklemede")
                                            {
                                                <span class="badge badge-warning text-white">Beklemede</span>
                                            }
                                            else if (item.Status == "Onaylandı")
                                            {
                                                <span class="badge badge-success">Onaylandı</span>
                                            }
                                            else if (item.Status == "İptal Edildi")
                                            {
                                                <span class="badge badge-danger">İptal Edildi</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-secondary">@item.Status</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <a href="/Order/UpdateOrder/@item.OrderId" class="btn btn-success btn-sm btn-icon-text mr-3">
                                                    Süreci Yönet
                                                    <i class="typcn typcn-edit btn-icon-append"></i>
                                                </a>
                                                <a href="/Order/DeleteOrder/@item.OrderId" class="btn btn-danger btn-sm btn-icon-text" onclick="return confirm('Bu sipariş kaydını silmek istediğinize emin misiniz?')">
                                                    Sil
                                                    <i class="typcn typcn-delete-outline btn-icon-append"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted">Henüz alınmış bir sipariş bulunmuyor.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                <div class="mt-4">
                    <a href="/Order/CreateOrder" class="btn btn-info btn-icon-text">
                        <i class="typcn typcn-plus mr-2"></i> Manuel Sipariş Oluştur
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>