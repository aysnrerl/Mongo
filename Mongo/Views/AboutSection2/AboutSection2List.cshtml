@model List<Mongo.Dtos.AboutSection2Dto.ResultAboutSection2Dto>
@{
    ViewData["Title"] = "Hakkımızda Bölüm 2";
    Layout = "~/Views/Admin/AdminLaoyut.cshtml";
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Hakkımızda - Bölüm 2 Yönetimi</h4>
                <p class="card-description">Ana sayfadaki ikinci hakkımızda / vizyon alanının içeriklerini buradan yönetebilirsiniz.</p>
                
                <div class="table-responsive pt-3">
                    <table class="table table-striped project-orders-table">
                        <thead>
                            <tr>
                                <th>Görsel</th>
                                <th>Başlık</th>
                                <th>Açıklama</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <img src="@item.ImageUrl" alt="Hakkımızda 2 Görseli" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;" />
                                        </td>
                                        <td class="font-weight-bold">@item.Title</td>
                                        <td>
                                            @(item.Description.Length > 70 ? item.Description.Substring(0, 70) + "..." : item.Description)
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <a href="/AboutSection2/UpdateAboutSection2/@item.AboutSection2Id" class="btn btn-success btn-sm btn-icon-text mr-3">
                                                    Düzenle
                                                    <i class="typcn typcn-edit btn-icon-append"></i>
                                                </a>
                                                <a href="/AboutSection2/DeleteAboutSection2/@item.AboutSection2Id" class="btn btn-danger btn-sm btn-icon-text" onclick="return confirm('Bu içeriği silmek istediğinize emin misiniz?')">
                                                    Sil
                                                    <i class="typcn typcn-delete-outline btn-icon-append"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted">Veri tabanında henüz içerik bulunmuyor.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                @if (Model == null || !Model.Any())
                {
                    <div class="mt-4">
                        <a href="/AboutSection2/CreateAboutSection2" class="btn btn-info btn-icon-text">
                            <i class="typcn typcn-plus mr-2"></i> Hakkımızda İçeriği Ekle
                        </a>
                    </div>
                }

            </div>
        </div>
    </div>
</div>