@model Mongo.Dtos.ProductDto.UpdateProductDto
@{
    ViewData["Title"] = "UpdateProduct";
    Layout = "~/Views/Admin/AdminLaoyut.cshtml";
    var categories = ViewBag.Categories as List<Mongo.Dtos.CategoryDto.ResultCategoryDto>;
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Ürün Güncelleme Sayfası</h4>
            <form method="post" class="forms-sample">
                <input type="hidden" asp-for="ProductId" />

                <div class="form-group">
                    <label>Kategori</label>
                    <select class="form-control" asp-for="CategoryName" required>
                        <option value="">-- Kategori Seçiniz --</option>
                        @if (categories != null)
                        {
                            foreach (var cat in categories)
                            {
                                <option value="@cat.CategoryName" selected="@(Model.CategoryName == cat.CategoryName ? "selected" : null)">@cat.CategoryName</option>
                            }
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label>Ürün Adı</label>
                    <input type="text" class="form-control" asp-for="ProductName" placeholder="Ürün Adı">
                </div>
                <div class="form-group">
                    <label>Ürün Yapım Zamanı</label>
                    <input type="text" class="form-control" asp-for="TotalTime" placeholder="Ürün Yapım Zamanı">
                </div>
                <div class="form-group">
                    <label>Ürünün Güncel Fiyatı</label>
                    <input type="text" class="form-control" asp-for="Price" placeholder="Ürünün Güncel Fiyatı">
                </div>
                <div class="form-group">
                    <label>Ürünün Eski Fiyatı</label>
                    <input type="text" class="form-control" asp-for="OldPrice" placeholder="Ürünün Eski Fiyatı">
                </div>
                <div class="form-group">
                    <label>Ürün Görseli</label>
                    <input type="text" class="form-control" asp-for="ImageUrl" placeholder="Ürün Görseli">
                </div>

                <button type="submit" class="btn btn-primary mr-2">Güncelle</button>
                <a href="/Product/ProductList" class="btn btn-light">İptal</a>
            </form>
        </div>
    </div>
</div>
