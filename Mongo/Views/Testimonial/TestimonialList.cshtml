@model List<Mongo.Dtos.TestimonialDto.ResultTestimonialDto>
@{
    ViewData["Title"] = "Müşteri Yorumları";
    Layout = "~/Views/Admin/AdminLaoyut.cshtml";
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Müşteri Yorumları / Referanslar</h4>
                <p class="card-description">Müşterilerinizin web siteniz hakkındaki değerli yorumlarını buradan yönetebilirsiniz.</p>
                
                <div class="table-responsive pt-3">
                    <table class="table table-striped project-orders-table">
                        <thead>
                            <tr>
                                <th>Profil</th>
                                <th>Ad Soyad</th>
                                <th>Unvan / Pozisyon</th>
                                <th>Yorum (Açıklama)</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <img src="@item.ImageUrl" alt="@item.NameSurname" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;" />
                                        </td>
                                        <td class="font-weight-bold">@item.NameSurname</td>
                                        <td><span class="badge bg-light text-dark fw-normal">@item.Pozition</span></td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.Description))
                                            {
                                                @(item.Description.Length > 60 ? item.Description.Substring(0, 60) + "..." : item.Description)
                                            }
                                            else
                                            {
                                                <span class="text-muted">Yorum girilmemiş.</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <a href="/Testimonial/UpdateTestimonial/@item.TestimonialId" class="btn btn-success btn-sm btn-icon-text mr-3">
                                                    Düzenle
                                                    <i class="typcn typcn-edit btn-icon-append"></i>
                                                </a>
                                                <a href="/Testimonial/DeleteTestimonial/@item.TestimonialId" class="btn btn-danger btn-sm btn-icon-text" onclick="return confirm('Bu müşteri yorumunu silmek istediğinize emin misiniz?')">
                                                    Sil
                                                    <i class="typcn typcn-delete-outline btn-icon-append"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted">Veri tabanında henüz müşteri yorumu bulunmuyor.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                <div class="mt-4">
                    <a href="/Testimonial/CreateTestimonial" class="btn btn-info btn-icon-text">
                        <i class="typcn typcn-plus mr-2"></i> Yeni Müşteri Yorumu Ekle
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>