@model Mongo.Dtos.FeatureDto.GetFeatureByIdDto
@{
    ViewData["Title"] = "Öne Çıkan İçeriği Güncelle";
    Layout = "~/Views/Admin/AdminLaoyut.cshtml";
}

<div class="row">
    <div class="col-md-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Öne Çıkan İçeriği Güncelle</h4>
                <p class="card-description">Mevcut kapak bilgilerini düzenlemek için aşağıdaki alanları güncelleyebilirsiniz.</p>
                
                <form class="forms-sample" method="post" action="/Feature/UpdateFeature">
                    
                    <input type="hidden" name="FeatureId" value="@Model.FeatureId" />

                    <div class="form-group">
                        <label for="Title">Ana Başlık</label>
                        <input type="text" class="form-control" id="Title" name="Title" value="@Model.Title" required>
                    </div>

                    <div class="form-group">
                        <label for="ImageUrl">Arka Plan Görsel URL</label>
                        <input type="text" class="form-control" id="ImageUrl" name="ImageUrl" value="@Model.ImageUrl" required>
                    </div>

                    <div class="form-group">
                        <label for="Description">Kısa Açıklama / Alt Başlık</label>
                        <textarea class="form-control" id="Description" name="Description" rows="4" required>@Model.Description</textarea>
                    </div>

                    <button type="submit" class="btn btn-primary mr-2">Değişiklikleri Kaydet</button>
                    <a href="/Feature/FeatureList" class="btn btn-light">İptal Et</a>
                    
                </form>
            </div>
        </div>
    </div>
</div>