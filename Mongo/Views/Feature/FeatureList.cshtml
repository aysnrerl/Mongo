@model List<Mongo.Dtos.FeatureDto.ResultFeatureDto>
@{
    ViewData["Title"] = "Öne Çıkanlar";
    Layout = "~/Views/Admin/AdminLaoyut.cshtml";
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Öne Çıkanlar (Slayt / Kapak) Yönetimi</h4>
                <p class="card-description">Ana sayfanın en üstünde yer alan iştah açıcı büyük kapak alanındaki içerikleri buradan yönetebilirsiniz.</p>
                
                <div class="table-responsive pt-3">
                    <table class="table table-striped project-orders-table">
                        <thead>
                            <tr>
                                <th>Görsel</th>
                                <th>Başlık</th>
                                <th>Açıklama</th>
                                <th>İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <img src="@item.ImageUrl" alt="Kapak Görseli" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;" />
                                        </td>
                                        <td class="font-weight-bold">@item.Title</td>
                                        <td>
                                            @(item.Description.Length > 70 ? item.Description.Substring(0, 70) + "..." : item.Description)
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <a href="/Feature/UpdateFeature/@item.FeatureId" class="btn btn-success btn-sm btn-icon-text mr-3">
                                                    Düzenle
                                                    <i class="typcn typcn-edit btn-icon-append"></i>
                                                </a>
                                                <a href="/Feature/DeleteFeature/@item.FeatureId" class="btn btn-danger btn-sm btn-icon-text" onclick="return confirm('Bu öne çıkan içeriği silmek istediğinize emin misiniz?')">
                                                    Sil
                                                    <i class="typcn typcn-delete-outline btn-icon-append"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted">Veri tabanında henüz öne çıkan içerik bulunmuyor.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                <div class="mt-4">
                    <a href="/Feature/CreateFeature" class="btn btn-info btn-icon-text">
                        <i class="typcn typcn-plus mr-2"></i> Yeni Öne Çıkan İçerik Ekle
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>