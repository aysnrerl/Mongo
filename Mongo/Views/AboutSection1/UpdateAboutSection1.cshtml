@model Mongo.Dtos.AboutSection1Dto.GetAboutSection1ByIdDto
@{
    ViewData["Title"] = "Hakkımızda İçeriğini Güncelle";
    Layout = "~/Views/Admin/AdminLaoyut.cshtml";
}

<div class="row">
    <div class="col-md-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Hakkımızda İçeriğini Güncelle</h4>
                <p class="card-description">Mevcut bilgileri düzenlemek için aşağıdaki alanları güncelleyip kaydedebilirsiniz.</p>
                
                <form class="forms-sample" method="post" action="/AboutSection1/UpdateAboutSection1">
                    
                    <input type="hidden" name="AboutSection1Id" value="@Model.AboutSection1Id" />

                    <div class="form-group">
                        <label for="Title">Başlık</label>
                        <input type="text" class="form-control" id="Title" name="Title" value="@Model.Title" required>
                    </div>

                    <div class="form-group">
                        <label for="ImageUrl">Görsel URL</label>
                        <input type="text" class="form-control" id="ImageUrl" name="ImageUrl" value="@Model.ImageUrl" required>
                    </div>

                    <div class="form-group">
                        <label for="Description">Açıklama / Hikayemiz</label>
                        <textarea class="form-control" id="Description" name="Description" rows="6" required>@Model.Description</textarea>
                    </div>

                    <button type="submit" class="btn btn-primary mr-2">Değişiklikleri Kaydet</button>
                    <a href="/AboutSection1/AboutSection1List" class="btn btn-light">İptal Et</a>
                    
                </form>
            </div>
        </div>
    </div>
</div>