@model List<Mongo.Dtos.SSSDto.ResultSSSDto>

<section class="faq-section" style="padding: 60px 0; background: #ffffff; width: 100%; display: block; clear: both;">
    <div class="container" style="max-width: 1140px; margin: 0 auto;">
        
        <div class="row mb-5">
            <div class="col-12 text-center">
                <span style="color: #a82c48; font-size: 14px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; display: block;">Merak Edilenler</span>
                <h2 style="font-size: 36px; font-weight: 700; color: #333333; margin: 10px 0;">Sıkça Sorulan Sorular</h2>
                <p style="color: #777777; font-size: 16px; max-width: 600px; margin: 0 auto;">Yemeklerimiz, teslimat süreçlerimiz ve siparişleriniz hakkında en çok sorulan soruları sizler için derledik.</p>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-10 col-md-12">
                <div class="faq-js-container" style="width: 100%;">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <div class="faq-item-box" style="background: #ffffff; border: 1px solid #eaeaea; border-radius: 6px; margin-bottom: 15px; width: 100%; display: block;">
                                
                                <div class="faq-js-trigger" style="display: flex; justify-content: space-between; align-items: center; width: 100%; padding: 20px 25px; cursor: pointer; font-size: 18px; font-weight: 600; color: #333333; user-select: none;">
                                    <span style="display: flex; align-items: center;"><i class="fa fa-question-circle mr-3" style="color: #a82c48; font-size: 20px;"></i> @item.Question</span>
                                    <i class="fa fa-chevron-down text-muted faq-icon" style="font-size: 14px; transition: transform 0.3s;"></i>
                                </div>

                                <div class="faq-js-content" style="display: none; padding: 5px 25px 25px 60px; color: #666666; font-size: 15px; line-height: 1.7; border-top: 1px solid #f9f9f9;">
                                    @item.Answer
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .faq-item-box {
        transition: all 0.2s ease-in-out;
    }

        .faq-item-box:hover {
            border-color: #d1d1d1 !important;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05) !important;
        }
        /* Aktif (Açık) olan elemanın stilleri */
        .faq-item-box.active .faq-js-trigger {
            color: #a82c48 !important;
        }

        .faq-item-box.active .faq-icon {
            transform: rotate(180deg);
            color: #a82c48 !important;
        }
</style>

<script>
    document.querySelectorAll('.faq-js-trigger').forEach(trigger => {
        trigger.addEventListener('click', function() {
            const parent = this.parentElement;
            const content = parent.querySelector('.faq-js-content');
            
            
            if (parent.classList.contains('active')) {
                parent.classList.remove('active');
                content.style.display = 'none';
            } else {
             
                document.querySelectorAll('.faq-item-box').forEach(item => {
                    item.classList.remove('active');
                    item.querySelector('.faq-js-content').style.display = 'none';
                });
                
                
                parent.classList.add('active');
                content.style.display = 'block';
            }
        });
    });
</script>