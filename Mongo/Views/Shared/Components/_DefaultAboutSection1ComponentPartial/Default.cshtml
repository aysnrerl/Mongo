@model List<Mongo.Dtos.AboutSection1Dto.ResultAboutSection1Dto>

@if (Model != null && Model.Any())
{
    foreach (var item in Model)
    {
        <div class="intro intro-about2">
            <div class="container">
                <div class="row center-content">
                    <div class="col-md-7 ">
                        <img src="@item.ImageUrl" class="pull-left img-responsive" alt="Hakkımızda Görsel 1" />
                    </div>
                    <div class="col-md-5">
                        <h3>@item.Title</h3>
                        <p>@item.Description</p>
                        <a href="#explore" class="btn btn-lg btn-primary">Daha Fazla Bilgi <i class="icon-arrow-right"></i></a>
                    </div>
                </div>
            </div>
        </div>
    }
}