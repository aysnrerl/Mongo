@model List<Mongo.Dtos.TestimonialDto.ResultTestimonialDto>

<div id="reviews" class="testimonials-color">
    <div class="container">
        <div class="about-inline text-center">
            <h3>Müşteri Değerlendirmeleri</h3>
        </div>
        <div class="row">
            <div class="col-md-12 text-center">
                <div class="quote2">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <div>
                                <img src="@item.ImageUrl" alt="@item.NameSurname" style="width:80px; height:80px; border-radius:50%; object-fit:cover;" />
                                <p>"@item.Description"</p>
                                <span class="author">@item.NameSurname - @item.Pozition</span>
                            </div>
                        }
                    }
                    else
                    {
                        <div>
                            <p>"Henüz müşteri yorumu girilmedi."</p>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="space100"></div>
    </div>
</div>