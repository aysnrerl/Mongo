@model List<Mongo.Dtos.AboutSection2Dto.ResultAboutSection2Dto>

@if (Model != null && Model.Any())
{
    foreach (var item in Model)
    {
        <div class="intro intro-about2">
            <div class="container">
                <div class="row center-content">
                    <div class="col-md-5">
                        <h3>@item.Title</h3>
                        <p>@item.Description</p>
							
                        <ul class="list">
                            <li><i class="fa fa-check"></i> 🌿 %100 Organik ve Sertifikalı Sızma Zeytinyağı</li>
                            <li><i class="fa fa-check"></i> 🌾 Her Sabah Taze Pişirilen Özel Ekşi Mayalı Ekmekler</li>
                            <li><i class="fa fa-check"></i> 🍅 Mevsiminde Toplanmış Katkısız Tarla Sebzelerir</li>
                        </ul>
							
                        <div class="space30"></div>
                        <a href="#explore" class="btn btn-lg btn-primary">Daha Fazla Bilgi <i class="icon-arrow-right"></i></a>
                    </div>
                    <div class="col-md-7">
                        <img src="@item.ImageUrl" class="pull-left img-responsive" alt="Hakkımızda Görsel 2" />
                    </div>
                </div>
            </div>
        </div>
    }
}