@model List<Mongo.Dtos.FeatureDto.ResultFeatureDto>

@if (Model != null && Model.Any())
{
    foreach (var item in Model)
    {
        <div class="intro intro3" style="background: url('@item.ImageUrl') no-repeat center center; background-size: cover !important; position: relative;">
            <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.55); z-index: 1;"></div>
            <div class="container" style="position: relative; z-index: 2;">
                <div class="row center-content">
                    <div class="col-md-5 col-sm-6">
                        <h3 style="color: #ffffff !important; text-shadow: 2px 2px 4px rgba(0,0,0,0.5);">@item.Title</h3>
                        <p style="color: #f0f0f0 !important;">@item.Description</p>
                        <div class="space30"></div>
                        <style>
                            .btn-custom-primary {
                                background-color: #a82d49 !important;
                                border-color: #a82d49 !important;
                                color: #fff !important;
                                border-radius: 30px !important;
                                font-weight: 600;
                                transition: all 0.3s ease !important;
                                padding: 12px 28px !important;
                            }
                            .btn-custom-primary:hover {
                                background-color: #8a2139 !important;
                                border-color: #8a2139 !important;
                                transform: translateY(-2px);
                                box-shadow: 0 6px 15px rgba(168, 45, 73, 0.4);
                            }
                            .btn-custom-outline {
                                color: #fff !important;
                                border: 2px solid #fff !important;
                                background: transparent !important;
                                border-radius: 30px !important;
                                font-weight: 600;
                                transition: all 0.3s ease !important;
                                padding: 10px 28px !important;
                            }
                            .btn-custom-outline:hover {
                                background-color: #fff !important;
                                color: #a82d49 !important;
                                border-color: #fff !important;
                                transform: translateY(-2px);
                                box-shadow: 0 6px 15px rgba(255, 255, 255, 0.2);
                            }
                        </style>
                        <div class="dual-btn">
                            <a href="#explore" class="btn btn-lg btn-custom-primary page-scroll">Şimdi Sipariş Ver &nbsp;<span class="fa fa-shopping-basket"></span></a> &nbsp; &nbsp;
                            <a href="#about" class="btn btn-lg btn-custom-outline page-scroll">Daha Fazla Bilgi &nbsp;<i class="fa fa-arrow-right"></i></a>
                        </div>
                    </div>
                    <div class="col-md-7 col-sm-6 no-padding">
                    </div>
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="intro intro3">
        <div class="container">
            <div class="row center-content">
                <div class="col-md-5 col-sm-6">
                    <h3>Lezzetin Güvenilir Adresi: Foodera</h3>
                    <p>Harika yemek seçimleri, kendinize yapacağınız en güzel yatırımdır. En taze ürünlerimizi denemek için menümüzü inceleyin.</p>
                </div>
            </div>
        </div>
    </div>
}