@model List<Mongo.Dtos.CategoryDto.ResultCategoryDto>
@{
    ViewData["Title"] = "CategoryList";
    Layout = "~/Views/Admin/AdminLaoyut.cshtml";
    int i = 0;
}
<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Kategori Yönetimi</h4>
            <div class="table-responsive pt-3">
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Kategori Adı</th>
                            <th>Açıklama</th>
                            <th>İkon</th>
                            <th>Sil</th>
                            <th>Güncelle</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            i++;
                            <tr>
                                <td>@i</td>
                                <td>@item.CategoryName</td>
                                <td>@item.Description</td>
                                <td>@item.IconUrl</td>
                                <td><a href="/Category/DeleteCategory/@item.CategoryId" class="btn btn-inverse-danger btn-fw">Sil</a></td>
                                <td><a href="/Category/UpdateCategory/@item.CategoryId" class="btn btn-inverse-warning btn-fw">Güncelle</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
                <br />
                <br />
                <a href="/Category/CreateCategory" class="btn btn-inverse-info btn-fw">Yeni Kategori Ekle</a>
            </div>
        </div>
    </div>
</div>
