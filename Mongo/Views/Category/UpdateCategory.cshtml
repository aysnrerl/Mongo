@model Mongo.Dtos.CategoryDto.UpdateCategoryDto
@{
    ViewData["Title"] = "UpdateCategory";
    Layout = "~/Views/Admin/AdminLaoyut.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Kategori Güncelleme Sayfası</h4>
            <form method="post" class="forms-sample">
                <input type="hidden" asp-for="CategoryId" />

                <div class="form-group">
                    <label>Kategori Adı</label>
                    <input type="text" class="form-control" asp-for="CategoryName" placeholder="Kategori Adı">
                </div>

                <div class="form-group">
                    <label>Açıklama</label>
                    <input type="text" class="form-control" asp-for="Description" placeholder="Açıklama">
                </div>

                <div class="form-group">
                    <label>İkon URL</label>
                    <input type="text" class="form-control" asp-for="IconUrl" placeholder="İkon URL">
                </div>

                <button type="submit" class="btn btn-primary mr-2">Güncelle</button>
                <a href="/Category/CategoryList" class="btn btn-light">İptal</a>
            </form>
        </div>
    </div>
</div>
