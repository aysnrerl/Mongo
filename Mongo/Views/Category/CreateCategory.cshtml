@{
    ViewData["Title"] = "CreateCategory";
    Layout = "~/Views/Admin/AdminLaoyut.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Yeni Kategori Ekleme Sayfası</h4>
            <form method="post" action="/Category/CreateCategory" class="forms-sample">

                <div class="form-group">
                    <label>Kategori Adı</label>
                    <input type="text" class="form-control" name="CategoryName" required />
                </div>

                <div class="form-group">
                    <label>Açıklama</label>
                    <input type="text" class="form-control" name="Description" />
                </div>

                <div class="form-group">
                    <label>İkon URL</label>
                    <input type="text" class="form-control" name="IconUrl" />
                </div>

                <button type="submit" class="btn btn-primary mr-2">Kategori Ekle</button>
                <a href="/Category/CategoryList" class="btn btn-light">İptal</a>
            </form>
        </div>
    </div>
</div>
